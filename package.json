{
  "name": "remotion-render-server",
  "version": "2.0.0",
  "description": "Remotion Lambda Express Server - Zeabur/Railway 部署版",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc --outDir dist",
    "start": "node dist/server.js",
    "deploy:lambda": "npx remotion lambda functions deploy --memory=2048 --disk=2048 --timeout=180 --region=ap-northeast-1",
    "deploy:site": "npx remotion lambda sites create src/index.ts --site-name=video-pipeline --region=ap-northeast-1",
    "ls:functions": "npx remotion lambda functions ls",
    "ls:sites": "npx remotion lambda sites ls"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/lambda": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "express": "^4.18.2",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

{
  "name": "remotion-render-server",
  "version": "3.0.0",
  "description": "Remotion 本機渲染 Server - 無需 AWS Lambda / GCP Cloud Run",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "ensure-browser": "node -e \"import('@remotion/renderer').then(m => m.ensureBrowser())\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@remotion/bundler": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "express": "^4.18.2",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
